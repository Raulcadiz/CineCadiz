<UserControl x:Class="CineCadiz.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource AppBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,24" MaxWidth="620" HorizontalAlignment="Left">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                <Button Command="{Binding GoBackCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="{StaticResource TextSecondary}"
                        Margin="0,0,12,0">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="22" Height="22" />
                </Button>
                <TextBlock Text="Ajustes" FontSize="26" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" />
            </StackPanel>

            <!-- ═══ SERVIDOR ═══ -->
            <TextBlock Text="SERVIDOR" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource AccentRed}" Margin="0,0,0,12"/>

            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="URL del servidor" Foreground="White" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0D0D0D" BorderBrush="#333"
                                 Foreground="White" CaretBrush="White"
                                 Padding="10,8" FontSize="13" FontFamily="Consolas"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="https://cinecadiz.servegame.com">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding SaveServerCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding SaveServerCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource AccentRed}" Foreground="White"
                                Margin="8,0,0,0" Padding="16,8" FontSize="13">
                            Guardar
                        </Button>
                        <Button Grid.Column="2" Command="{Binding ResetServerCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#555" Foreground="{StaticResource TextSecondary}"
                                Margin="6,0,0,0" Padding="12,8" FontSize="12"
                                ToolTip="Volver al servidor predeterminado">
                            Reset
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ ACTUALIZAR CONTENIDO ═══ -->
            <TextBlock Text="CONTENIDO" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource AccentRed}" Margin="0,24,0,12"/>

            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Actualizar contenido" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Recarga películas, series y canales desde el servidor"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,3,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding RefreshContentCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource AccentRed}" Foreground="White"
                            Padding="16,8" FontSize="13" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Actualizar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ LISTAS M3U PERSONALIZADAS ═══ -->
            <TextBlock Text="LISTAS M3U PERSONALIZADAS" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource AccentRed}" Margin="0,24,0,12"/>

            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16,14" Margin="0,0,0,4">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <materialDesign:PackIcon Kind="PlaylistPlay" Foreground="#4CAF50"
                                                 Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="Añade tus propias listas M3U"
                                       Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Aparecerán en la sección En vivo junto a las listas del servidor"
                                       Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Input row -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding NewM3uUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0D0D0D" BorderBrush="#333"
                                 Foreground="White" CaretBrush="White"
                                 Padding="10,8" FontSize="12" FontFamily="Consolas"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="https://miservidor.com/lista.m3u">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AddM3uCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding AddM3uCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource AccentRed}" Foreground="White"
                                Margin="8,0,0,0" Padding="14,8" FontSize="13">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"/>
                        </Button>
                    </Grid>

                    <!-- List of saved M3U URLs -->
                    <ItemsControl ItemsSource="{Binding CustomM3uList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D0D0D" CornerRadius="6" Padding="12,8"
                                        Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="PlaylistPlay"
                                                                 Foreground="#4CAF50"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="12" FontFamily="Consolas"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="2"
                                                Command="{Binding DataContext.RemoveM3uCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Foreground="#666" Width="28" Height="28">
                                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Sin listas M3U personalizadas"
                               Foreground="#444" FontSize="12" TextAlignment="Center"
                               Margin="0,6,0,2">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CustomM3uList.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ═══ CONTROL REMOTO (WiFi) ═══ -->
            <TextBlock Text="CONTROL REMOTO (WiFi)" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource AccentRed}" Margin="0,24,0,12"/>

            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <materialDesign:PackIcon Kind="CellphoneWireless" Foreground="#4CAF50"
                                                 Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Abre esta URL en el navegador del móvil"
                                       Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="(mismo WiFi que el PC)"
                                       Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Background="#0D0D0D" CornerRadius="6" Padding="14,10" Margin="0,0,0,4">
                        <TextBlock Text="{Binding RemoteUrl}"
                                   Foreground="{StaticResource AccentRed}"
                                   FontSize="16" FontWeight="Bold"
                                   FontFamily="Consolas"
                                   TextAlignment="Center"/>
                    </Border>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="0,8,0,0"
                               TextWrapping="Wrap">
                        Controla reproducción, volumen y navegación desde cualquier dispositivo en tu red local.
                    </TextBlock>
                    <Button Command="{Binding OpenFirewallRuleCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#555" Foreground="{StaticResource TextSecondary}"
                            Padding="12,6" FontSize="12" Margin="0,10,0,0"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShieldOutline" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Abrir puerto en Firewall (admin)" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ═══ HISTORIAL ═══ -->
            <TextBlock Text="HISTORIAL" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource AccentRed}" Margin="0,24,0,12"/>

            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16,14" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Contenido visto" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WatchedCount}" Foreground="{StaticResource TextSecondary}"
                                   FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding ClearHistoryCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            BorderBrush="#555" Foreground="{StaticResource TextSecondary}"
                            Padding="12,6" FontSize="12">
                        Borrar historial
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ ACERCA DE ═══ -->
            <TextBlock Text="ACERCA DE" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource AccentRed}" Margin="0,24,0,12"/>

            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="16,14" Margin="0,0,0,32">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Versión" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding AppVersion}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="13" VerticalAlignment="Center" />
                    </Grid>
                    <Separator Background="#333" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Plataforma" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Windows (WPF / .NET 8)"
                                   Foreground="{StaticResource TextSecondary}" FontSize="13" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
