<Window x:Class="CineCadiz.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CineCadiz.ViewModels"
        xmlns:views="clr-namespace:CineCadiz.Views"
        xmlns:converters="clr-namespace:CineCadiz.Converters"
        Title="CINE CÁDIZ"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="900"
        Background="{StaticResource AppBackground}"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        KeyDown="Window_KeyDown"
        StateChanged="Window_StateChanged">

    <!-- WindowChrome: native resize + snap, custom caption -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="56"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}"    Executed="OnClose"/>
        <CommandBinding Command="{x:Static SystemCommands.MinimizeWindowCommand}" Executed="OnMinimize"/>
        <CommandBinding Command="{x:Static SystemCommands.MaximizeWindowCommand}" Executed="OnMaximize"/>
        <CommandBinding Command="{x:Static SystemCommands.RestoreWindowCommand}"  Executed="OnRestore"/>
    </Window.CommandBindings>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:NavIconColorConverter x:Key="NavIconColorConverter"/>
        <!-- Window control button style -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1E1E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="WinBtnClose" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E53935"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Outer border for a subtle window edge -->
    <Border BorderBrush="#1E1E1E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="72"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ CUSTOM TITLE BAR ═══ -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="#111111"
                    Panel.ZIndex="10">
                <!-- Red accent line at bottom -->
                <Border.BorderBrush><SolidColorBrush Color="#E53935"/></Border.BorderBrush>
                <Border.BorderThickness>0,0,0,2</Border.BorderThickness>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>    <!-- sidebar width -->
                        <ColumnDefinition Width="Auto"/>  <!-- logo -->
                        <ColumnDefinition Width="*"/>     <!-- search -->
                        <ColumnDefinition Width="300"/>   <!-- search box -->
                        <ColumnDefinition Width="Auto"/>  <!-- window buttons -->
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                        <TextBlock FontSize="19" FontWeight="Black" Foreground="White">CINE</TextBlock>
                        <TextBlock FontSize="19" FontWeight="Black" Foreground="{StaticResource AccentRed}"
                                   Margin="5,0,0,0">CÁDIZ</TextBlock>
                    </StackPanel>

                    <!-- Search bar -->
                    <Border Grid.Column="3"
                            Background="#1E1E1E" CornerRadius="20"
                            Padding="14,0" VerticalAlignment="Center" Height="34"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="White" CaretBrush="White"
                                     VerticalAlignment="Center"
                                     materialDesign:HintAssist.Hint="Buscar..."
                                     materialDesign:HintAssist.Foreground="#55FFFFFF"
                                     Style="{StaticResource MaterialDesignTextBox}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" Command="{Binding SearchCommand}"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Foreground="#888" Width="30" Height="30">
                                <materialDesign:PackIcon Kind="Magnify" Width="17" Height="17"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Window control buttons (always on top of chrome) -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Style="{StaticResource WinBtn}"
                                Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                ToolTip="Minimizar">
                            <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource WinBtn}"
                                ToolTip="Maximizar / Restaurar"
                                Click="MaxRestoreButton_Click">
                            <materialDesign:PackIcon x:Name="MaxIcon" Kind="WindowMaximize" Width="16" Height="16"/>
                        </Button>
                        <Button Style="{StaticResource WinBtnClose}"
                                Command="{x:Static SystemCommands.CloseWindowCommand}"
                                ToolTip="Cerrar">
                            <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ SIDEBAR ═══ -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource SidebarBackground}">
                <Grid>
                    <StackPanel VerticalAlignment="Top" Margin="0,8">
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateHomeCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Home" Width="24" Height="24" HorizontalAlignment="Center"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=0}"/>
                                <TextBlock Text="Inicio" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=0}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateMoviesCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Movie" Width="24" Height="24" HorizontalAlignment="Center"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=1}"/>
                                <TextBlock Text="Películas" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=1}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateSeriesCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Television" Width="24" Height="24" HorizontalAlignment="Center"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=2}"/>
                                <TextBlock Text="Series" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=2}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateLiveCommand}">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Broadcast" Width="24" Height="24" HorizontalAlignment="Center"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=3}"/>
                                <TextBlock Text="En vivo" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=3}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                        <Separator Background="#252525" Margin="12,0"/>
                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateSettingsCommand}" Margin="0,4,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Cog" Width="24" Height="24" HorizontalAlignment="Center"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=4}"/>
                                <TextBlock Text="Ajustes" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"
                                    Foreground="{Binding SelectedNavIndex, Converter={StaticResource NavIconColorConverter}, ConverterParameter=4}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl Grid.Row="1" Grid.Column="1"
                            Content="{Binding CurrentView}"
                            Background="{StaticResource AppBackground}"/>

            <!-- Player Overlay -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2" Panel.ZIndex="100"
                  Visibility="{Binding Player.IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <views:PlayerView DataContext="{Binding Player}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
