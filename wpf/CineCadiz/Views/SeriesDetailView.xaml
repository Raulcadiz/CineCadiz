<UserControl x:Class="CineCadiz.Views.SeriesDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:CineCadiz.Models"
             Background="{StaticResource AppBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="Auto" />  <!-- Season tabs -->
            <RowDefinition Height="*" />     <!-- Episodes -->
        </Grid.RowDefinitions>

        <!-- Loading bar -->
        <ProgressBar IsIndeterminate="True" Height="2" Panel.ZIndex="10"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                     Foreground="{StaticResource AccentRed}" />

        <!-- Header -->
        <Grid Grid.Row="0" Height="180" ClipToBounds="True">
            <!-- Blurred backdrop -->
            <Image Source="{Binding Series.Image, Converter={StaticResource ImageUrlConverter}}"
                   Stretch="UniformToFill" Opacity="0.3">
                <Image.Effect>
                    <BlurEffect Radius="20" />
                </Image.Effect>
            </Image>
            <Border Background="#AA000000" />

            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Cover -->
                <Border Grid.Column="0" CornerRadius="6" ClipToBounds="True"
                        Width="90" Height="135" Margin="0,0,20,0">
                    <Image Source="{Binding Series.Image, Converter={StaticResource ImageUrlConverter}}"
                           Stretch="UniformToFill" />
                </Border>

                <!-- Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Series.Title}"
                               FontSize="24" FontWeight="Bold" Foreground="White"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Foreground="#AAA" FontSize="13" Text="{Binding Series.Year}" />
                        <TextBlock Foreground="#555" Margin="8,0">·</TextBlock>
                        <TextBlock Foreground="#AAA" FontSize="13">
                            <Run Text="{Binding Series.SeasonCount}" />
                            <Run Text=" temporadas" />
                        </TextBlock>
                        <TextBlock Foreground="#555" Margin="8,0">·</TextBlock>
                        <TextBlock Foreground="#AAA" FontSize="13">
                            <Run Text="{Binding Series.EpisodeCount}" />
                            <Run Text=" episodios" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Back button -->
                <Button Grid.Column="2" VerticalAlignment="Top"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Foreground="White" ToolTip="Volver">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="22" Height="22" />
                </Button>
            </Grid>
        </Grid>

        <!-- Season tabs -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Background="#161616" Padding="16,8">
            <ItemsControl ItemsSource="{Binding Seasons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource CategoryChip}"
                                Tag="{Binding}"
                                Click="SeasonChip_Click">
                            <TextBlock>
                                <Run Text="Temporada " />
                                <Run Text="{Binding}" />
                            </TextBlock>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Episodes list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,8,24,16">
            <ItemsControl ItemsSource="{Binding Episodes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ContentItem}">
                        <Border Background="{StaticResource CardBackground}"
                                CornerRadius="6" Margin="0,0,0,8" Padding="12,10"
                                Cursor="Hand"
                                MouseLeftButtonUp="Episode_Click"
                                Tag="{Binding}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2A2A" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Foreground="{StaticResource AccentRed}"
                                           FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center">
                                    <Run Text="E" />
                                    <Run Text="{Binding Episode}" />
                                </TextBlock>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           Foreground="White" FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="8,0" />

                                <materialDesign:PackIcon Grid.Column="2"
                                                          Kind="PlayCircleOutline"
                                                          Width="22" Height="22"
                                                          Foreground="{StaticResource AccentRed}"
                                                          VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
