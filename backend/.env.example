# ── Copia este archivo a .env y rellena los valores ──────────
# cp .env.example .env && nano .env

# Clave secreta de Flask (genera una con: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura

# Credenciales del superadmin (primer arranque)
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-contrasena

# Base de datos (SQLite por defecto, no cambiar salvo que uses PostgreSQL)
# DATABASE_URL=sqlite:///instance/cinemacity.db

# Escáner automático: 1=activado, 0=desactivado
AUTO_SCAN=1

# Intervalo entre escaneos VOD (horas)
SCAN_INTERVAL_HOURS=24

# Workers paralelos del escáner (más = más rápido, más CPU)
SCAN_MAX_WORKERS=40

# Tamaño de lote del escáner
SCAN_BATCH_SIZE=5000

# Días antes de eliminar streams caídos permanentemente
PURGE_DEAD_DAYS=7
