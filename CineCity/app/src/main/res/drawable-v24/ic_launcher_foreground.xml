<?xml version="1.0" encoding="utf-8"?>
<!--
  Icono CineCity — Tira de película + botón Play
  Zona segura adaptive icon: 72dp centrados en 108dp → rango ~18–90
  Diseño visual efectivo: x=21–87, y=19–89
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ══ Cuerpo principal de la tira (dorado/ámbar) ══ -->
    <path
        android:fillColor="#D4AF37"
        android:pathData="M21,19 L87,19 L87,89 L21,89 Z" />

    <!-- ══ Pantalla interior oscura ══ -->
    <path
        android:fillColor="#0D0D1A"
        android:pathData="M21,34 L87,34 L87,74 L21,74 Z" />

    <!-- ══ Perforaciones superiores (3 huecos) ══ -->
    <path
        android:fillColor="#0D0D1A"
        android:pathData="M28,22 L36,22 L36,30 L28,30 Z
                          M50,22 L58,22 L58,30 L50,30 Z
                          M72,22 L80,22 L80,30 L72,30 Z" />

    <!-- ══ Perforaciones inferiores (3 huecos) ══ -->
    <path
        android:fillColor="#0D0D1A"
        android:pathData="M28,78 L36,78 L36,86 L28,86 Z
                          M50,78 L58,78 L58,86 L50,86 Z
                          M72,78 L80,78 L80,86 L72,86 Z" />

    <!-- ══ Botón Play (triángulo blanco centrado en la pantalla) ══
         Vértices calculados para centroide exacto en (54,54):
         (46,38) · (46,70) · (70,54)  →  centroide = ((46+46+70)/3, (38+70+54)/3) = (54,54) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,38 L46,70 L70,54 Z" />

</vector>
